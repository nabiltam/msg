{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and presence information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["uid", "displayName"]
    },
    "Message": {
      "title": "Message",
      "description": "A private message between two users",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "conversationId": { "type": "string" }
      },
      "required": ["text", "senderId", "createdAt", "conversationId"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Metadata for a private chat between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat metadata"
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
